DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cineconnect
JWT_SECRET=dev-secret-change-en-prod
PORT=3001

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Auth cookie
AUTH_COOKIE_NAME=cineconnect_auth

# Google OAuth (Authorization Code flow) — crée des identifiants dans Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Redirects after auth
FRONTEND_AUTH_REDIRECT=http://localhost:5173/profil
FRONTEND_GOOGLE_COMPLETE_REDIRECT=http://localhost:5173/complete-username

# OMDb (https://www.omdbapi.com/) — utilisée uniquement par le backend ; jamais exposée au navigateur
OMDB_API_KEY=

# Optionnel : nombre de jours avant de rafraîchir une entrée cache (0 = pas d’expiration)
# OMDB_CACHE_MAX_AGE_DAYS=30
